VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# 必須。surveyConfig のキーと一致させる（例: natori-park または default）
VITE_SURVEY_CONFIG=natori-park
# 本番ビルドでは必須。保存される environment は Edge Function の SUBMIT_ENVIRONMENT（別途設定）
VITE_ENVIRONMENT=test

# Python集計スクリプト用（フロントには絶対に渡さない）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
AGGREGATE_EVENT_ID=natori-park
AGGREGATE_ENVIRONMENT=production

# --- Supabase Edge Function `submit-response`（ダッシュボードの Secrets または `supabase secrets set`）
# SUBMIT_ENVIRONMENT=test   または production（このプロジェクトに保存する行の environment 列の値）
